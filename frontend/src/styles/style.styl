@require "colors"
@require "fonts"
@require "nav"
@require "icons"
@require "sidebar"
@require "post"
@require "feed"
@require "error"

body
    font-family: $sans-serif

a
    text-decoration: inherit
    color: inherit

.main-container
    width: 100%
    display: flex
    justify-content: center

.link-underline
    position: relative
    text-decoration: none

.link-underline::before
    content: ""
    position: absolute
    display: block
    width: 100%
    height: 2px
    background-color: $red
    bottom: 0
    left: 0
    transform: scaleX(0)
    transition: transform 0.3s ease

.link-underline:hover::before
    transform: scaleX(0.9)
